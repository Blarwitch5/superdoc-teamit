---
/**
 * Layout de base pour les pages hors Starlight (login, admin).
 *
 * Props :
 *   title     — contenu du <title>
 *   centered  — centre le body en flex (page login)
 *   forceDark — force data-theme="dark" sans lire le localStorage (page login)
 */
import ThemeInitScript from '../components/ThemeInitScript.astro'
import '../styles/app.css'

interface Props {
  title: string
  centered?: boolean
  forceDark?: boolean
}

const { title, centered = false, forceDark = false } = Astro.props
---

<!DOCTYPE html>
<html lang="fr" data-theme={forceDark ? 'dark' : undefined}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {/* ThemeInitScript lit le localStorage — on le saute si le thème est forcé */}
  {!forceDark && <ThemeInitScript />}
  <style is:global>
    /* Tokens et utilitaires → app.css (importé dans le frontmatter) */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: var(--bg);
      font-family: system-ui, -apple-system, 'Helvetica Neue', Arial, sans-serif;
      color: var(--text);
      transition: background 0.2s, color 0.2s;
    }

    body.centered {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body class:list={[{ centered }]}>
  <slot />
</body>
</html>
