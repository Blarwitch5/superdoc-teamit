---
import { auth } from '../lib/auth'

const response = await auth.api.signOut({
  headers: Astro.request.headers,
  asResponse: true,
})

// Forward cookies cleared by better-auth (don't hardcode cookie names)
const redirectHeaders = new Headers({ location: '/login' })
const setCookies = (response.headers as any).getSetCookie?.() as string[] | undefined
  ?? (response.headers.get('set-cookie') ? [response.headers.get('set-cookie')!] : [])
for (const cookie of setCookies) redirectHeaders.append('set-cookie', cookie)

return new Response(null, { status: 302, headers: redirectHeaders })
---
