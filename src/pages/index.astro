---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { readFileSync } from 'node:fs'
import { join } from 'node:path'
import {
  readOrder, getCategoryDirs, getCategoryLabel,
  getOrderedFiles, parseFrontmatter, DOCS_PATH
} from '../lib/content'

const order     = readOrder()
const dirs      = getCategoryDirs(order)

type FicheCard  = { title: string; href: string }
type CategoryCard = {
  dir:    string
  label:  string
  icon:   string
  fiches: FicheCard[]
}

const ICONS: Record<string, string> = {
  email:         `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
  administratif: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  installation:  `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
  serveur:       `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
  web:           `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  default:       `<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>`,
}

const categories: CategoryCard[] = dirs.flatMap(dir => {
  const files = getOrderedFiles(dir, order)
  if (!files.length) return []

  const fiches: FicheCard[] = files.map(file => {
    const slug = file.replace(/\.(mdx|md|mdoc)$/, '')
    try {
      const fm = parseFrontmatter(readFileSync(join(DOCS_PATH, dir, file), 'utf-8'))
      return { title: fm.title || slug, href: `/${dir}/${slug}/` }
    } catch {
      return { title: slug, href: `/${dir}/${slug}/` }
    }
  })

  return [{
    dir,
    label:  getCategoryLabel(dir),
    icon:   ICONS[dir] ?? ICONS.default,
    fiches,
  }]
})

const totalFiches = categories.reduce((sum, c) => sum + c.fiches.length, 0)
---

<StarlightPage frontmatter={{
  title: 'Accueil',
  description: 'Base de connaissances interne Team IT — fiches de process et guides techniques.'
}}>

  <div class="home">

    <!-- Hero -->
    <div class="hero">
      <h1 class="hero-title">Base de connaissances <span class="accent">Team IT</span></h1>
      <p class="hero-desc">
        Procédures, guides et fiches techniques pour l'équipe IT. <br />
        <strong>{totalFiches} fiches</strong> réparties en <strong>{categories.length} catégories</strong>.
      </p>
    </div>

    <!-- Category grid -->
    <div class="grid">
      {categories.map((cat, i) => (
        <div class="card" style={i >= 2 && i % 2 === 1 ? 'margin-top:1.5rem' : undefined}>
          <div class="card-head">
            <span class="card-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon} />
            </span>
            <span class="card-title">{cat.label}</span>
            <span class="card-count">{cat.fiches.length}</span>
          </div>
          <ul class="card-list">
            {cat.fiches.slice(0, 3).map(f => (
              <li>
                <a href={f.href}>{f.title}</a>
              </li>
            ))}
          </ul>
          {cat.fiches.length > 3 && (
            <button class="card-more" data-expand-cat={cat.label} type="button">
              +{cat.fiches.length - 3} autres fiches →
            </button>
          )}
        </div>
      ))}
    </div>

    <script>
      document.querySelectorAll<HTMLButtonElement>('[data-expand-cat]').forEach(btn => {
        btn.addEventListener('click', () => {
          const label = btn.dataset.expandCat!
          // Find the matching <details> in the sidebar
          const details = Array.from(document.querySelectorAll<HTMLDetailsElement>('nav details'))
            .find(d => {
              const summary = d.querySelector('summary')
              return summary?.textContent?.trim() === label
            })
          if (details) {
            details.open = true
            details.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
          }
        })
      })
    </script>

  </div>

</StarlightPage>

<style>
  .home {
    max-width: 860px;
  }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .hero-title {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    color: var(--sl-color-white);
  }

  .accent {
    color: var(--sl-color-accent);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Grid ────────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .card { margin-top: 0 !important; }
  }

  /* ── Card ────────────────────────────────────────────── */
  .card {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.625rem;
    padding: 1.125rem 1.25rem;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--sl-color-accent);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    border-radius: 0.4rem;
    color: var(--sl-color-accent);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--sl-color-white);
    flex: 1;
  }

  .card-count {
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--sl-color-accent);
    color: #fff;
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
    flex-shrink: 0;
  }

  /* ── Fiche list ──────────────────────────────────────── */
  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .card-list li a {
    display: block;
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    padding: 0.3rem 0.4rem;
    border-radius: 0.3rem;
    transition: color 0.1s, background 0.1s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-list li a:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-bg-sidebar);
  }

  .card-more {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.25rem 0.4rem;
    background: none;
    border: none;
    color: var(--sl-color-accent);
    font-size: 0.75rem;
    font-family: inherit;
    cursor: pointer;
    border-radius: 0.25rem;
    transition: background 0.1s;
  }
  .card-more:hover {
    background: var(--sl-color-bg-sidebar);
  }
</style>
