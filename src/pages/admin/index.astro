---
import { join, basename } from 'node:path'
import { readFileSync, readdirSync } from 'node:fs'
import AppLayout from '../../layouts/AppLayout.astro'
import ThemeSwitcher from '../../components/ThemeSwitcher.astro'
import TeamItLogo from '../../components/TeamItLogo.astro'
import { parseFrontmatter, readOrder, getCategoryDirs, DOCS_PATH } from '../../lib/content'

const user = Astro.locals.user!
const savedOrder = readOrder()

type Fiche    = { slug: string; title: string; description: string; modifiedAt: string; id: string }
type Category = { dir: string; label: string; fiches: Fiche[] }

const categories: Category[] = []

for (const dir of getCategoryDirs(savedOrder)) {
  const dirPath = join(DOCS_PATH, dir)

  // Read label from category index.mdx frontmatter
  let label = dir.charAt(0).toUpperCase() + dir.slice(1)
  try {
    const fm = parseFrontmatter(readFileSync(join(dirPath, 'index.mdx'), 'utf-8'))
    if (fm.title) label = fm.title
  } catch {}

  // List fiches, excluding the category index page
  let rawFiles: string[] = []
  try {
    rawFiles = readdirSync(dirPath)
      .filter(f => /\.(mdx|md|mdoc)$/.test(f) && !/^index\.(mdx|md|mdoc)$/.test(f))
  } catch {}

  const ficheOrder = savedOrder.fiches[dir] ?? []
  const orderedFiles = [
    ...ficheOrder.map(s => rawFiles.find(f => f.replace(/\.(mdx|md|mdoc)$/, '') === s)).filter(Boolean) as string[],
    ...rawFiles.filter(f => !ficheOrder.includes(f.replace(/\.(mdx|md|mdoc)$/, ''))).sort(),
  ]

  const fiches: Fiche[] = orderedFiles.map(file => {
    const slug = basename(file).replace(/\.(mdx|md|mdoc)$/, '')
    try {
      const fm = parseFrontmatter(readFileSync(join(dirPath, file), 'utf-8'))
      return { slug, title: fm.title || slug, description: fm.description || '', modifiedAt: fm.modifiedAt || fm.createdAt || '', id: `${dir}/${slug}` }
    } catch {
      return { slug, title: slug, description: '', modifiedAt: '', id: `${dir}/${slug}` }
    }
  })

  categories.push({ dir, label, fiches })
}

const totalFiches = categories.reduce((sum, c) => sum + c.fiches.length, 0)
---

<AppLayout title="Administration — Documentation Team IT">
  <header>
    <div class="header-left">
      <div class="logo-bg">
        <TeamItLogo height={24} aria-hidden />
      </div>
      <span class="header-title">Administration</span>
    </div>
    <div class="header-right">
      <ThemeSwitcher />
      <span class="user-info">{user.name || user.email}</span>
      <a href="/" class="btn btn-ghost">← Docs</a>
      <a href="/logout" class="btn-logout">Déconnexion</a>
    </div>
  </header>

  <main>
    <div class="page-header">
      <div>
        <h1 class="page-title">Fiches de process</h1>
        <p class="page-meta">{totalFiches} fiche{totalFiches > 1 ? 's' : ''} · {categories.length} catégorie{categories.length > 1 ? 's' : ''}</p>
      </div>
      <div class="page-actions">
        <button class="btn btn-secondary" id="toggle-add-cat">+ Catégorie</button>
        <a href="/keystatic/collection/fiches/create" class="btn btn-primary">+ Nouvelle fiche</a>
      </div>
    </div>

    <div id="add-category-form">
      <div class="form-row">
        <div class="form-field">
          <label for="cat-name">Nom de la catégorie</label>
          <input type="text" id="cat-name" placeholder="ex : Réseau, Sécurité…" autocomplete="off" />
          <span class="form-hint">Converti automatiquement en minuscules sans accents.</span>
        </div>
        <div class="form-field">
          <label for="cat-desc">Description (optionnel)</label>
          <input type="text" id="cat-desc" placeholder="Courte description pour la sidebar." />
        </div>
      </div>
      <div class="form-error" id="cat-error"></div>
      <div class="form-row" style="justify-content:flex-end;gap:0.5rem;">
        <button class="btn btn-ghost" id="cancel-add-cat">Annuler</button>
        <button class="btn btn-primary" id="submit-add-cat">Créer la catégorie</button>
      </div>
    </div>

    <template id="grip-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <circle cx="9" cy="5" r="1.5"/><circle cx="15" cy="5" r="1.5"/>
        <circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/>
        <circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="19" r="1.5"/>
      </svg>
    </template>

    <div class="accordion" id="accordion">
      {categories.map(cat => (
        <details open data-cat={cat.dir}>
          <summary>
            <div class="summary-left">
              <div class="drag-handle cat-drag-handle" title="Glisser pour réorganiser"></div>
              <span class="category-label">{cat.label}</span>
              <span class="category-count">{cat.fiches.length}</span>
            </div>
            <div class="summary-right">
              <button
                class="btn-delete-cat"
                data-cat={cat.dir}
                data-label={cat.label}
                title={cat.fiches.length > 0
                  ? `Suppression impossible : ${cat.fiches.length} fiche(s) présente(s)`
                  : `Supprimer la catégorie ${cat.label}`}
                disabled={cat.fiches.length > 0}
                aria-label={`Supprimer ${cat.label}`}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
                </svg>
              </button>
              <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </div>
          </summary>

          {cat.fiches.length > 0 ? (
            <div class="fiches-list">
              {cat.fiches.map(fiche => (
                <div class="fiche-item" draggable="true" data-fiche={fiche.slug} data-cat={cat.dir}>
                  <div class="drag-handle fiche-drag-handle" title="Glisser pour réorganiser"></div>
                  <div class="fiche-info">
                    <div class="fiche-title">{fiche.title}</div>
                    {fiche.description && <div class="fiche-description">{fiche.description}</div>}
                  </div>
                  <div class="fiche-actions">
                    {fiche.modifiedAt && <span class="fiche-date">{fiche.modifiedAt}</span>}
                    <a href={`/${cat.dir}/${fiche.slug}/`} class="btn-view" target="_blank" rel="noopener">Voir</a>
                    <a href={`/keystatic/collection/fiches/item/${encodeURIComponent(fiche.id)}`} class="btn-edit">Modifier</a>
                  </div>
                </div>
              ))}
              <div class="new-fiche-row">
                <a href="/keystatic/collection/fiches/create" class="btn-new-fiche">+ Ajouter une fiche</a>
              </div>
            </div>
          ) : (
            <div class="empty">
              Aucune fiche. <a href="/keystatic/collection/fiches/create">Créer la première →</a>
            </div>
          )}
        </details>
      ))}
    </div>
  </main>

  <div id="toast" role="status" aria-live="polite"></div>
</AppLayout>

<style>
  /* ── Header ── */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .header-left { display: flex; align-items: center; gap: 1rem; }
  .logo-bg { background: #fff; border-radius: 4px; padding: 3px 6px; line-height: 0; }
  .header-title { font-size: 0.8125rem; color: var(--muted); border-left: 1px solid var(--border); padding-left: 1rem; }
  .header-right { display: flex; align-items: center; gap: 0.75rem; }
  .user-info { font-size: 0.8125rem; color: var(--muted); }

  /* ── Buttons ── */
  .btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.875rem; border-radius: 0.375rem;
    font-size: 0.8125rem; font-weight: 500;
    text-decoration: none; cursor: pointer; border: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: var(--accent-hover); }
  .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
  .btn-ghost:hover { color: var(--text); border-color: var(--muted); }
  .btn-secondary { background: var(--surface-hover); color: var(--text); border: 1px solid var(--border); }
  .btn-secondary:hover { border-color: var(--muted); }
  .btn-logout { font-size: 0.8125rem; color: var(--subtle); text-decoration: none; transition: color 0.15s; }
  .btn-logout:hover { color: var(--muted); }

  /* ── Main ── */
  main { max-width: 860px; margin: 0 auto; padding: 2.5rem 2rem; }

  .page-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 2rem; gap: 1rem;
  }
  .page-title { font-size: 1.25rem; font-weight: 700; }
  .page-meta { font-size: 0.8125rem; color: var(--muted); margin-top: 0.25rem; }
  .page-actions { display: flex; gap: 0.5rem; }

  /* ── Add category form ── */
  #add-category-form {
    display: none; background: var(--surface);
    border: 1px solid var(--border); border-radius: 0.5rem;
    padding: 1.25rem; margin-bottom: 1.25rem;
    gap: 0.75rem; flex-direction: column;
  }
  #add-category-form.visible { display: flex; }
  .form-row { display: flex; gap: 0.75rem; align-items: flex-end; }
  .form-field { display: flex; flex-direction: column; gap: 0.375rem; flex: 1; }
  .form-field label { font-size: 0.8rem; color: var(--muted); }
  .form-field input {
    padding: 0.5rem 0.75rem; background: var(--input-bg);
    border: 1px solid var(--input-border); border-radius: 0.375rem;
    color: var(--text); font-size: 0.875rem;
  }
  .form-field input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(223,49,35,0.15); }
  .form-hint { font-size: 0.75rem; color: var(--subtle); }
  .form-error { font-size: 0.8rem; color: #f87171; display: none; }
  .form-error.visible { display: block; }

  /* ── Drag handle ── */
  .drag-handle {
    display: flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; flex-shrink: 0;
    color: var(--subtle); cursor: grab; border-radius: 3px;
    opacity: 0.25; transition: opacity 0.15s, color 0.15s;
  }
  .drag-handle:active { cursor: grabbing; }

  /* ── Accordion ── */
  .accordion { display: flex; flex-direction: column; gap: 0.75rem; }

  details {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 0.5rem; overflow: hidden;
  }
  details:hover > summary .drag-handle { opacity: 0.7; }
  details > summary:hover .drag-handle,
  details > summary .drag-handle:hover { opacity: 1; }

  details.is-dragging { opacity: 0.4; }
  details.drag-over-top    { box-shadow: 0 -3px 0 var(--accent); }
  details.drag-over-bottom { box-shadow: 0 3px 0 var(--accent); }

  summary {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.875rem 1rem 0.875rem 0.5rem;
    cursor: pointer; user-select: none; list-style: none; gap: 0.5rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary:hover { background: var(--surface-hover); }

  .summary-left { display: flex; align-items: center; gap: 0.5rem; }
  .category-label { font-weight: 600; font-size: 0.9375rem; }
  .category-count {
    font-size: 0.75rem; color: var(--muted);
    background: var(--border); padding: 0.15rem 0.5rem; border-radius: 999px;
  }
  .summary-right { display: flex; align-items: center; gap: 0.75rem; }

  .chevron { color: var(--muted); transition: transform 0.2s; flex-shrink: 0; }
  details[open] .chevron { transform: rotate(180deg); }

  .btn-delete-cat {
    display: inline-flex; align-items: center; justify-content: center;
    width: 26px; height: 26px; border-radius: 0.25rem;
    border: 1px solid transparent; background: transparent;
    color: var(--subtle); cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .btn-delete-cat:hover { color: #f87171; border-color: #f87171; background: rgba(248,113,113,0.08); }
  .btn-delete-cat:disabled { opacity: 0.25; cursor: not-allowed; pointer-events: none; }

  /* ── Fiche list ── */
  .fiches-list { border-top: 1px solid var(--border-subtle); }

  .fiche-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.625rem 1rem 0.625rem 0.5rem; gap: 0.75rem;
    border-bottom: 1px solid var(--border-subtle);
    cursor: default;
  }
  .fiche-item:last-child { border-bottom: none; }
  .fiche-item:hover { background: var(--surface-hover); }
  .fiche-item:hover .drag-handle { opacity: 0.8; }

  .fiche-item.is-dragging { opacity: 0.4; }
  .fiche-item.drag-over-top    { box-shadow: 0 -2px 0 var(--accent); }
  .fiche-item.drag-over-bottom { box-shadow: 0 2px 0 var(--accent); }

  .fiche-info { flex: 1; min-width: 0; }
  .fiche-title { font-size: 0.875rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fiche-description { font-size: 0.8rem; color: var(--muted); margin-top: 0.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .fiche-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .fiche-date { font-size: 0.75rem; color: var(--subtle); }

  .btn-edit {
    font-size: 0.75rem; padding: 0.25rem 0.625rem;
    border-radius: 0.25rem; text-decoration: none;
    color: var(--muted); border: 1px solid var(--border);
    transition: color 0.15s, border-color 0.15s; white-space: nowrap;
  }
  .btn-edit:hover { color: var(--accent); border-color: var(--accent); }
  .btn-view {
    font-size: 0.75rem; padding: 0.25rem 0.625rem;
    border-radius: 0.25rem; text-decoration: none;
    color: var(--muted); border: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s; white-space: nowrap;
  }
  .btn-view:hover { color: var(--text); border-color: var(--border); }

  .new-fiche-row { padding: 0.5rem 1rem; border-top: 1px solid var(--border-subtle); }
  .btn-new-fiche {
    font-size: 0.8rem; color: var(--subtle); text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.35rem; transition: color 0.15s;
  }
  .btn-new-fiche:hover { color: var(--accent); }

  .empty { padding: 1.25rem 1rem; font-size: 0.875rem; color: var(--subtle); border-top: 1px solid var(--border-subtle); }
  .empty a { color: var(--accent); text-decoration: none; }

  /* ── Toast ── */
  #toast {
    position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    background: var(--surface); color: var(--text);
    padding: 0.625rem 1.25rem; border-radius: 0.375rem;
    font-size: 0.875rem; border: 1px solid var(--border);
    opacity: 0; pointer-events: none; transition: opacity 0.2s;
    white-space: nowrap; z-index: 100;
  }
  #toast.show { opacity: 1; }
  #toast.error { border-color: #f87171; color: #f87171; }
</style>

<script>
  // ── Inject grip icons ──────────────────────────────────────────────
  const grip = (document.getElementById('grip-icon') as HTMLTemplateElement).content
  document.querySelectorAll('.drag-handle').forEach(el => {
    el.appendChild(grip.cloneNode(true))
  })

  // ── Toast ────────────────────────────────────────────────────────
  function toast(msg: string, isError = false) {
    const el = document.getElementById('toast')!
    el.textContent = msg
    el.className = isError ? 'error show' : 'show'
    setTimeout(() => { el.className = isError ? 'error' : '' }, 2500)
  }

  // ── Save order ───────────────────────────────────────────────────
  async function saveOrder() {
    const accordion = document.getElementById('accordion')!
    const cats = [...accordion.querySelectorAll<HTMLElement>('details[data-cat]')]
    const categories = cats.map(el => el.dataset.cat!)
    const fiches: Record<string, string[]> = {}
    for (const el of cats) {
      const cat = el.dataset.cat!
      fiches[cat] = [...el.querySelectorAll<HTMLElement>('.fiche-item[data-fiche]')].map(f => f.dataset.fiche!)
    }
    try {
      const res = await fetch('/api/admin/order', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ categories, fiches }),
      })
      if (!res.ok) toast('Erreur lors de la sauvegarde', true)
    } catch {
      toast('Erreur réseau', true)
    }
  }

  // ── Category drag & drop ─────────────────────────────────────────
  const accordion = document.getElementById('accordion')!
  let catDragEl: HTMLElement | null = null

  document.querySelectorAll<HTMLElement>('.cat-drag-handle').forEach(handle => {
    const details = handle.closest<HTMLElement>('details')!
    handle.addEventListener('mousedown', (e) => {
      e.stopPropagation()
      details.draggable = true
    })
    window.addEventListener('mouseup', () => {
      if (catDragEl !== details) details.draggable = false
    })
  })

  accordion.addEventListener('dragstart', (e) => {
    const details = (e.target as HTMLElement).closest<HTMLElement>('details[data-cat]')
    if (!details || !details.draggable) return
    catDragEl = details
    details.classList.add('is-dragging')
    e.dataTransfer!.effectAllowed = 'move'
    e.dataTransfer!.setData('text/plain', 'cat')
    details.removeAttribute('open')
  }, true)

  accordion.addEventListener('dragend', (e) => {
    const details = (e.target as HTMLElement).closest<HTMLElement>('details[data-cat]')
    if (!details) return
    details.classList.remove('is-dragging')
    details.draggable = false
    details.setAttribute('open', '')
    document.querySelectorAll('.drag-over-top, .drag-over-bottom').forEach(el => {
      el.classList.remove('drag-over-top', 'drag-over-bottom')
    })
    catDragEl = null
  }, true)

  accordion.addEventListener('dragover', (e) => {
    if (!catDragEl) return
    const target = (e.target as HTMLElement).closest<HTMLElement>('details[data-cat]')
    if (!target || target === catDragEl) return
    e.preventDefault()
    e.dataTransfer!.dropEffect = 'move'
    const rect = target.getBoundingClientRect()
    const before = e.clientY < rect.top + rect.height / 2
    target.classList.toggle('drag-over-top', before)
    target.classList.toggle('drag-over-bottom', !before)
  })

  accordion.addEventListener('dragleave', (e) => {
    const target = (e.target as HTMLElement).closest<HTMLElement>('details[data-cat]')
    if (target && !target.contains(e.relatedTarget as Node)) {
      target.classList.remove('drag-over-top', 'drag-over-bottom')
    }
  })

  accordion.addEventListener('drop', (e) => {
    if (!catDragEl) return
    const target = (e.target as HTMLElement).closest<HTMLElement>('details[data-cat]')
    if (!target || target === catDragEl) return
    e.preventDefault()
    const rect = target.getBoundingClientRect()
    const before = e.clientY < rect.top + rect.height / 2
    accordion.insertBefore(catDragEl, before ? target : target.nextSibling)
    target.classList.remove('drag-over-top', 'drag-over-bottom')
    saveOrder()
  })

  // ── Fiche drag & drop (same category only) ──────────────────────
  let ficheDragEl: HTMLElement | null = null

  document.querySelectorAll<HTMLElement>('.fiche-item').forEach(item => {
    item.addEventListener('dragstart', (e) => {
      ficheDragEl = item
      item.classList.add('is-dragging')
      e.dataTransfer!.effectAllowed = 'move'
      e.dataTransfer!.setData('text/plain', 'fiche')
      e.stopPropagation()
    })

    item.addEventListener('dragend', () => {
      item.classList.remove('is-dragging')
      document.querySelectorAll('.fiche-item.drag-over-top, .fiche-item.drag-over-bottom').forEach(el => {
        el.classList.remove('drag-over-top', 'drag-over-bottom')
      })
      ficheDragEl = null
    })

    item.addEventListener('dragover', (e) => {
      if (!ficheDragEl || ficheDragEl === item || ficheDragEl.dataset.cat !== item.dataset.cat) return
      e.preventDefault()
      e.stopPropagation()
      e.dataTransfer!.dropEffect = 'move'
      const before = e.clientY < item.getBoundingClientRect().top + item.getBoundingClientRect().height / 2
      item.classList.toggle('drag-over-top', before)
      item.classList.toggle('drag-over-bottom', !before)
    })

    item.addEventListener('dragleave', (e) => {
      if (!item.contains(e.relatedTarget as Node)) {
        item.classList.remove('drag-over-top', 'drag-over-bottom')
      }
    })

    item.addEventListener('drop', (e) => {
      if (!ficheDragEl || ficheDragEl === item || ficheDragEl.dataset.cat !== item.dataset.cat) return
      e.preventDefault()
      e.stopPropagation()
      const rect = item.getBoundingClientRect()
      const before = e.clientY < rect.top + rect.height / 2
      item.parentElement!.insertBefore(ficheDragEl, before ? item : item.nextSibling)
      item.classList.remove('drag-over-top', 'drag-over-bottom')
      saveOrder()
    })
  })

  // ── Add category form ────────────────────────────────────────────
  const addForm   = document.getElementById('add-category-form')!
  const toggleBtn = document.getElementById('toggle-add-cat')!
  const cancelBtn = document.getElementById('cancel-add-cat')!
  const submitBtn = document.getElementById('submit-add-cat')!
  const nameInput = document.getElementById('cat-name') as HTMLInputElement
  const descInput = document.getElementById('cat-desc') as HTMLInputElement
  const errorEl   = document.getElementById('cat-error')!

  function showError(msg: string) {
    errorEl.textContent = msg
    errorEl.classList.add('visible')
  }

  toggleBtn.addEventListener('click', () => {
    addForm.classList.toggle('visible')
    if (addForm.classList.contains('visible')) nameInput.focus()
  })

  cancelBtn.addEventListener('click', () => {
    addForm.classList.remove('visible')
    nameInput.value = ''
    descInput.value = ''
    errorEl.classList.remove('visible')
  })

  submitBtn.addEventListener('click', async () => {
    const name = nameInput.value.trim()
    if (!name) { showError('Le nom est requis.'); return }
    submitBtn.textContent = 'Création…'
    submitBtn.setAttribute('disabled', '')
    const res = await fetch('/api/admin/category', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, description: descInput.value.trim() }),
    })
    const data = await res.json()
    submitBtn.textContent = 'Créer la catégorie'
    submitBtn.removeAttribute('disabled')
    if (!res.ok) { showError(data.error ?? 'Erreur inconnue.'); return }
    toast(`Catégorie « ${data.label} » créée.`)
    location.reload()
  })

  nameInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitBtn.click() })

  // ── Delete category ──────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.btn-delete-cat').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation()
      const dir = btn.dataset.cat!
      const label = btn.dataset.label!
      if (!confirm(`Supprimer la catégorie « ${label} » ?\nCette action est irréversible.`)) return
      const res = await fetch('/api/admin/category', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: dir }),
      })
      const data = await res.json()
      if (!res.ok) { toast(data.error ?? 'Erreur inconnue.', true); return }
      toast(`Catégorie « ${label} » supprimée.`)
      location.reload()
    })
  })
</script>
