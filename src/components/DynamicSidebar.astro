---
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro'
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro'
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter'
import { readFileSync } from 'node:fs'
import { join, basename } from 'node:path'
import { parseFrontmatter, readOrder, getCategoryDirs, getOrderedFiles, DOCS_PATH } from '../lib/content'

type SidebarLink  = { type: 'link';  label: string; href: string; isCurrent: boolean; badge: undefined; attrs: Record<string, unknown> }
type SidebarGroup = { type: 'group'; label: string; entries: SidebarEntry[]; collapsed: boolean; badge: undefined }
type SidebarEntry = SidebarLink | SidebarGroup

const currentPath = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/'
const isActive = (href: string) => currentPath === (href.replace(/\/$/, '') || '/')

const savedOrder = readOrder()
const sidebar: SidebarEntry[] = []

for (const dir of getCategoryDirs(savedOrder)) {
  const dirPath = join(DOCS_PATH, dir)

  // Label comes from the category index.mdx frontmatter
  let label = dir.charAt(0).toUpperCase() + dir.slice(1)
  try {
    const fm = parseFrontmatter(readFileSync(join(dirPath, 'index.mdx'), 'utf-8'))
    if (fm.title) label = fm.title
  } catch {}

  const files = getOrderedFiles(dir, savedOrder)
  if (!files.length) continue

  const items = files.map(file => {
    const slug = basename(file).replace(/\.(mdx|md|mdoc)$/, '')
    const href = slug === 'index' ? `/${dir}/` : `/${dir}/${slug}/`
    try {
      const fm = parseFrontmatter(readFileSync(join(dirPath, file), 'utf-8'))
      return { href, title: fm.title || slug, subcategory: fm.subcategory || '' }
    } catch {
      return { href, title: slug, subcategory: '' }
    }
  })

  const toLink = (item: typeof items[number]): SidebarLink => ({
    type: 'link',
    label: item.title,
    href: item.href,
    isCurrent: isActive(item.href),
    badge: undefined,
    attrs: {},
  })

  if (!items.some(item => item.subcategory)) {
    sidebar.push({ type: 'group', label, collapsed: false, badge: undefined, entries: items.map(toLink) })
    continue
  }

  // Group by subcategory; ungrouped items appear first
  const ungrouped = items.filter(item => !item.subcategory)
  const grouped: Record<string, typeof items> = {}
  for (const item of items.filter(item => item.subcategory)) {
    (grouped[item.subcategory] ??= []).push(item)
  }

  sidebar.push({
    type: 'group',
    label,
    collapsed: false,
    badge: undefined,
    entries: [
      ...ungrouped.map(toLink),
      ...Object.entries(grouped)
        .sort(([a], [b]) => a.localeCompare(b, 'fr'))
        .map(([sub, subItems]): SidebarGroup => ({
          type: 'group',
          label: sub,
          collapsed: false,
          badge: undefined,
          entries: subItems.map(toLink),
        })),
    ],
  })
}
---

<SidebarPersister>
  <SidebarSublist sublist={sidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>
