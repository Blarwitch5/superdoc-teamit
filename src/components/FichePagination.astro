---
import { readFileSync } from 'node:fs'
import { join, basename } from 'node:path'
import { parseFrontmatter, readOrder, getCategoryDirs, getOrderedFiles, DOCS_PATH } from '../lib/content'

type FicheLink = { href: string; title: string }

// Build flat ordered list of all fiches (same order as sidebar)
const savedOrder = readOrder()
const allFiches: FicheLink[] = []

for (const dir of getCategoryDirs(savedOrder)) {
  for (const file of getOrderedFiles(dir, savedOrder)) {
    const slug = basename(file).replace(/\.(mdx|md|mdoc)$/, '')
    const href = `/${dir}/${slug}/`
    let title = slug
    try {
      const fm = parseFrontmatter(readFileSync(join(DOCS_PATH, dir, file), 'utf-8'))
      if (fm.title) title = fm.title
    } catch {}
    allFiches.push({ href, title })
  }
}

// Find current page from Starlight route entry id (e.g. "web/creation-hebergement-infomaniak")
const entryId    = Astro.locals.starlightRoute?.entry?.id ?? ''
const currentIdx = allFiches.findIndex(f => f.href === `/${entryId}/`)

const prev = currentIdx > 0 ? allFiches[currentIdx - 1] : null
const next = currentIdx >= 0 && currentIdx < allFiches.length - 1 ? allFiches[currentIdx + 1] : null
---

{(prev || next) && (
  <nav class="pagination-nav" aria-label="Navigation entre fiches">
    <div class="pagination-side">
      {prev && (
        <a href={prev.href} class="pagination-link prev" rel="prev">
          <span class="pagination-dir">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            Précédente
          </span>
          <span class="pagination-title">{prev.title}</span>
        </a>
      )}
    </div>
    <div class="pagination-side pagination-right">
      {next && (
        <a href={next.href} class="pagination-link next" rel="next">
          <span class="pagination-dir">
            Suivante
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
          <span class="pagination-title">{next.title}</span>
        </a>
      )}
    </div>
  </nav>
)}

<style>
  .pagination-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .pagination-side {
    flex: 1;
    min-width: 0;
  }

  .pagination-right {
    text-align: right;
  }

  .pagination-link {
    display: inline-flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    transition: color 0.15s;
    max-width: 100%;
  }
  .pagination-link:hover { color: var(--sl-color-white); }

  .pagination-dir {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
  }

  .next .pagination-dir {
    justify-content: flex-end;
  }

  .pagination-title {
    font-size: 0.9375rem;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pagination-link:hover .pagination-title {
    color: var(--sl-color-accent);
  }
</style>
