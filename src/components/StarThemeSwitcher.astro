---
// Replaces Starlight's default ThemeSelect with the same icon-based switcher as admin pages.
// Uses Starlight CSS variables so it fits the nav bar.
// Syncs via the 'starlight-theme' localStorage key (same as Starlight's native toggle).
---

<div class="ts-wrap" role="group" aria-label="Thème d'affichage">
  <button class="ts-btn" data-theme-set="light" title="Thème clair">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
  <button class="ts-btn" data-theme-set="auto" title="Thème système">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="3" width="20" height="14" rx="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
    </svg>
  </button>
  <button class="ts-btn" data-theme-set="dark" title="Thème sombre">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</div>

<style>
  .ts-wrap {
    display: inline-flex;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    overflow: hidden;
    flex-shrink: 0;
  }
  .ts-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 24px;
    background: transparent;
    border: none;
    border-right: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .ts-btn:last-child { border-right: none; }
  .ts-btn:hover { background: var(--sl-color-bg-sidebar); color: var(--sl-color-white); }
  .ts-btn.active { color: var(--sl-color-accent); }
</style>

<script>
  const STORAGE_KEY = 'starlight-theme'

  function resolveTheme(stored: string): 'dark' | 'light' {
    if (stored === 'dark') return 'dark'
    if (stored === 'light') return 'light'
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
  }

  function applyTheme(stored: string) {
    document.documentElement.dataset.theme = resolveTheme(stored)
  }

  function updateButtons(stored: string) {
    document.querySelectorAll<HTMLElement>('[data-theme-set]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.themeSet === stored)
    })
  }

  const initial = localStorage.getItem(STORAGE_KEY) || 'auto'
  updateButtons(initial)

  document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach(btn => {
    btn.addEventListener('click', () => {
      const value = btn.dataset.themeSet!
      localStorage.setItem(STORAGE_KEY, value)
      applyTheme(value)
      updateButtons(value)
    })
  })

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if ((localStorage.getItem(STORAGE_KEY) || 'auto') === 'auto') applyTheme('auto')
  })
</script>
