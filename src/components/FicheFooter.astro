---
import type { Props } from '@astrojs/starlight/props'

const { entry } = Astro.props as Props
const isLoggedIn = !!Astro.locals.user

type FicheData = {
  category?:    string
  subcategory?: string
  createdBy?:   string
  createdAt?:   string
  modifiedBy?:  string
  modifiedAt?:  string
}

const data = entry?.data as FicheData | undefined

// Only render on real fiches (not category index pages)
const isFiche = entry?.id && !(/\/index$/.test(entry.id)) && entry.id.includes('/')
if (!isFiche) return

function val(s: string | undefined): string {
  return s?.trim() ?? ''
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr)
  const date = d.toLocaleDateString('fr-CH', { day: 'numeric', month: 'long', year: 'numeric' })
  if (!dateStr.includes('T')) return date
  const h = String(d.getHours()).padStart(2, '0')
  const m = String(d.getMinutes()).padStart(2, '0')
  return `${date} à ${h}h${m}`
}

const createdBy  = val(data?.createdBy)
const createdAt  = val(data?.createdAt)
const modifiedBy = val(data?.modifiedBy)
const modifiedAt = val(data?.modifiedAt)

const hasCreated  = !!createdBy
const hasModified = !!modifiedBy && modifiedAt !== createdAt

const slashIdx = entry!.id.indexOf('/')
const editUrl  = isLoggedIn
  ? `/admin/fiche/?cat=${entry!.id.slice(0, slashIdx)}&slug=${entry!.id.slice(slashIdx + 1)}`
  : null
---

{(hasCreated || hasModified) && (
  <footer class="fiche-footer">
    {hasCreated && (
      <p>
        Créé par <strong>{createdBy}</strong>
        {createdAt && <> le {formatDate(createdAt)}</>}
      </p>
    )}
    {hasModified && (
      <p>
        Modifié par <strong>{modifiedBy}</strong>
        {modifiedAt && <> le {formatDate(modifiedAt)}</>}
      </p>
    )}
  </footer>
)}

<style>
  .fiche-footer {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .fiche-footer strong {
    color: var(--sl-color-text);
    font-weight: 600;
  }
</style>
