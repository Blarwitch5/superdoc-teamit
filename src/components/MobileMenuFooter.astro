---
const user = Astro.locals.user
const isLoggedIn = !!user
---

{isLoggedIn && (
  <div class="mobile-user">
    <div class="mobile-user-name">{user!.name || user!.email}</div>
    <nav class="mobile-user-nav">
      <a href="/admin/fiche/">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouvelle fiche
      </a>
      <a href="/admin">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Gérer les fiches
      </a>
      <a href="/change-password">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Mon compte
      </a>
      <a href="/logout" class="danger">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Déconnexion
      </a>
    </nav>
  </div>
)}

<style>
  .mobile-user {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 1rem 1rem 0.5rem;
    margin-top: 0.5rem;
  }

  .mobile-user-name {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.5rem;
    padding: 0 0.25rem;
  }

  .mobile-user-nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .mobile-user-nav a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.5rem;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background 0.1s, color 0.1s;
  }
  .mobile-user-nav a:hover {
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-white);
  }
  .mobile-user-nav a:first-child {
    color: var(--sl-color-accent);
    font-weight: 600;
  }
  .mobile-user-nav a.danger {
    color: var(--sl-color-red, #e85748);
  }
  .mobile-user-nav a.danger:hover {
    background: rgba(232, 87, 72, 0.08);
  }
</style>
