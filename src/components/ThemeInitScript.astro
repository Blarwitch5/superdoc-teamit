<!-- Run before paint to avoid flash. Place in <head> before any <style>. -->
<script is:inline>
  (function () {
    try {
      var t = localStorage.getItem('starlight-theme') || 'auto';
      var dark = t === 'dark' || (t === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.dataset.theme = dark ? 'dark' : 'light';
    } catch (e) {}
  })();
</script>
